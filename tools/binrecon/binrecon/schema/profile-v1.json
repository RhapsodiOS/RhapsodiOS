{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "profile-v1.json",
  "title": "Binrecon profile, version 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "name", "architecture", "reference", "rebuilt", "analyzers", "comparison", "output_dir"],
  "properties": {
    "schema_version": {"const": "profile-v1"},
    "name": {"type": "string"},
    "architecture": {"type": "string"},
    "reference": {"$ref": "#/$defs/binary"},
    "rebuilt": {"$ref": "#/$defs/binary"},
    "analyzers": {"$ref": "#/$defs/analyzers"},
    "comparison": {"$ref": "#/$defs/comparison"},
    "output_dir": {"type": "string"},
    "endianness": {"enum": ["little", "big"]},
    "image_base": {"type": "integer", "minimum": 0},
    "regions": {"type": "array", "items": {"$ref": "#/$defs/region"}},
    "aliases": {"$ref": "#/$defs/aliases"},
    "symbolic_checks": {"type": "array", "items": {"$ref": "#/$defs/symbolic_check"}},
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9A-Fa-f]{64}$"},
    "binary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {"type": "string"},
        "expected_size": {"type": "integer", "minimum": 0},
        "expected_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "analyzer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "executable": {"type": "string"},
        "timeout_seconds": {"type": "integer", "minimum": 1},
        "version": {"type": "string"}
      }
    },
    "analyzers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ida": {"$ref": "#/$defs/analyzer"},
        "ghidra": {"$ref": "#/$defs/analyzer"},
        "angr": {"$ref": "#/$defs/analyzer"}
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance", "ignore_metadata", "entry_points"],
      "properties": {
        "acceptance": {
          "enum": ["exact-image", "exact-sections", "normalized-functions"]
        },
        "ignore_metadata": {"type": "array", "items": {"type": "string"}},
        "entry_points": {"type": "array", "items": {"type": "string"}}
      }
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "address", "offset", "size", "permissions"],
      "properties": {
        "name": {"type": "string"},
        "address": {"type": "integer", "minimum": 0},
        "offset": {"type": "integer", "minimum": 0},
        "size": {"type": "integer", "minimum": 0},
        "permissions": {"type": "string"}
      }
    },
    "aliases": {
      "type": "object",
      "propertyNames": {"type": "string", "minLength": 1},
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "symbolic_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "function", "max_active_states", "max_steps"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "function": {"type": "string", "minLength": 1},
        "max_active_states": {"type": "integer", "minimum": 1},
        "max_steps": {"type": "integer", "minimum": 1},
        "input_bytes": {"type": "integer", "minimum": 0},
        "registers": {"$ref": "#/$defs/registers"},
        "memory": {
          "type": "array",
          "items": {"$ref": "#/$defs/memory_state"}
        },
        "hooks": {
          "type": "array",
          "items": {"$ref": "#/$defs/hook"}
        },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {"$ref": "#/$defs/return_equals"},
              {"$ref": "#/$defs/memory_equals"},
              {"$ref": "#/$defs/return_equivalent"}
            ]
          }
        }
      }
    },
    "registers": {
      "type": "object",
      "propertyNames": {"type": "string", "minLength": 1},
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "memory_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["address", "bytes"],
      "properties": {
        "address": {"type": "integer", "minimum": 0},
        "bytes": {"type": "string", "pattern": "^(?:[0-9A-Fa-f]{2})+$"}
      }
    },
    "hook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["address", "handler"],
      "properties": {
        "address": {"type": "integer", "minimum": 0},
        "handler": {"type": "string", "minLength": 1},
        "returns": {"type": "integer"}
      }
    },
    "return_equals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": {"const": "return-equals"},
        "value": {"type": "integer"}
      }
    },
    "memory_equals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "address", "bytes"],
      "properties": {
        "kind": {"const": "memory-equals"},
        "address": {"type": "integer", "minimum": 0},
        "bytes": {"type": "string", "pattern": "^(?:[0-9A-Fa-f]{2})+$"}
      }
    },
    "return_equivalent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "artifact"],
      "properties": {
        "kind": {"const": "return-equivalent"},
        "artifact": {"enum": ["reference", "rebuilt"]}
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": {"type": "string", "minLength": 1},
      "additionalProperties": {}
    }
  }
}
